# ───────────────────────────────────────────────
# SECRETS & ENVIRONMENT — never commit
# ───────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets/
*.key
*.pem
*.crt
*.p12
*.pfx

# ───────────────────────────────────────────────
# SENSITIVE USER DATA — never commit
# ───────────────────────────────────────────────
resumes/
data/resumes/
uploads/
generated/
*.resume
*.docx
*.pdf
screenshots/
*.png
*.jpg
*.jpeg

# ───────────────────────────────────────────────
# DATABASE DUMPS & VOLUMES — never commit
# ───────────────────────────────────────────────
*.sql.gz
*.dump
*.bak
backups/
db_data/
postgres_data/
pgdata/

# ───────────────────────────────────────────────
# TLS / Let's Encrypt
# ───────────────────────────────────────────────
certbot/
letsencrypt/
nginx/ssl/

# ───────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ───────────────────────────────────────────────
# Node / React
# ───────────────────────────────────────────────
node_modules/
dist/
build/
.cache/
npm-debug.log*
yarn-error.log*

# ───────────────────────────────────────────────
# Docker / runtime
# ───────────────────────────────────────────────
*.log
logs/

# ───────────────────────────────────────────────
# OS / IDE
# ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
