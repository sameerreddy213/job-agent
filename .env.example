# ============================================================
# job-agent environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# ---- Deployment ----
DOMAIN=jobs.example.com
ACME_EMAIL=sameerreddy213@gmail.com
ENVIRONMENT=production

# ---- Backend / API ----
API_HOST=0.0.0.0
API_PORT=8000
# Generate a strong random value, e.g. openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7
# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# ---- Single admin user (seeded on first run) ----
ADMIN_USERNAME=admin
# Set a strong password; it will be hashed (argon2/bcrypt) at seed time
ADMIN_PASSWORD=change_me_strong_password

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobagent
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=change_me_db_password
# Full URL the app uses
DATABASE_URL=postgresql+psycopg://jobagent:change_me_db_password@postgres:5432/jobagent

# ---- Pipeline / scheduler ----
SCAN_INTERVAL_MINUTES=60
DATA_RETENTION_DAYS=365

# ---- Test mode (no real job boards) ----
# When true, the pipeline loads SAMPLE_JOB_COUNT synthetic jobs instead of
# calling Greenhouse/Lever/Ashby. Lets you exercise filter/score/dedupe/API.
TEST_MODE=true
SAMPLE_JOB_COUNT=50
HTTP_TIMEOUT_SECONDS=20

# ---- Scoring thresholds ----
SCORE_AUTO_APPROVE=90
SCORE_REVIEW=70

# ---- Telegram (alerts only; no approvals) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Google Sheets (one-way mirror, Phase 6B) ----
# Provide EITHER an inline service-account JSON (preferred) OR a file path.
# Never commit either. Share the target sheet with the service account email.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google_sa.json
GOOGLE_SHEET_ID=
SHEETS_SYNC_ENABLED=false
SHEETS_SYNC_INTERVAL_MINUTES=30

# ---- GitHub backup (config/infra drift) ----
GITHUB_REPO=github.com/sameerreddy213/job-agent
# Fine-grained PAT with repo write; used by github-backup.sh (kept out of git)
GITHUB_TOKEN=

# ---- AWS (future services; optional for MVP) ----
# Prefer an EC2 IAM instance role over static keys. Leave blank if using a role.
AWS_REGION=ap-south-1
AWS_S3_BACKUP_BUCKET=
CLOUDWATCH_ENABLED=false

# ---- AI provider (optional, WI-3) ----
# Leave AI_PROVIDER empty to use deterministic templates (no LLM, no cost).
# Set AI_PROVIDER=openrouter and AI_API_KEY=<your OpenRouter key> to LLM-polish
# cover letters + the open-ended application answer. OpenRouter is OpenAI-compatible.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=openai/gpt-4o-mini
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MAX_TOKENS=900
AI_TIMEOUT_SECONDS=30
